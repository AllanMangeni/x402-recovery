{
  "name": "x402-recovery",
  "version": "0.3.1",
  "description": "Late settlement recovery for x402 facilitator timeouts.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && cp src/beav3r-shim.d.ts dist/beav3r-shim.d.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "x402",
    "payment",
    "settlement",
    "recovery",
    "middleware"
  ],
  "author": "Allan Mang'eni Wanyonyi",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AllanMangeni/x402-recovery.git"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "viem": "^2.49.2"
  },
  "peerDependencies": {
    "express": "^4.21.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/express": "^5.0.0",
    "@types/node": "^25.8.0",
    "express": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  }
}
